## ElevenLabs
# Get an API key from your ElevenLabs account and paste it here.
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY"

# Optional: choose a voice ID (defaults to a built-in fallback in code if empty).
ELEVENLABS_VOICE_ID=

# Optional: override models (defaults in code).
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STT_MODEL_ID=scribe_v1

## Firecrawl (Doctor Registry Verification)
# Used during doctor signup to verify the doctor exists on an external registry site.
FIRECRAWL_API_KEY="fc-f866a00a0ea440819593f35883151640"

# Template URL of the registry search page you want to scrape.
# Use placeholders: {username} and {registrationNumber}
# Example: https://example.com/search?name={username}&reg={registrationNumber}
DOCTOR_REGISTRY_SEARCH_URL=

# Optional: override Firecrawl base URL (defaults to https://api.firecrawl.dev)
FIRECRAWL_API_BASE_URL=
